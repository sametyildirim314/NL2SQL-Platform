# ============================================================
# NL2SQL Platform – Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# ============================================================

# ─── PostgreSQL ───
POSTGRES_DB=nl2sql
POSTGRES_USER=nl2sql_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PORT=5432

# ─── Redis ───
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_PORT=6379

# ─── AI Backend ───
OPENAI_API_KEY=sk-your-openai-api-key-here
AI_BACKEND_PORT=8000
AI_WORKERS=2
# OPENAI_MODEL=gpt-4o

# ─── Core Backend (.NET 8) ───
CORE_BACKEND_PORT=8001
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_min_32_chars
ENVIRONMENT=development

# ─── Frontend ───
FRONTEND_PORT=3000

# ─── General ───
LOG_LEVEL=info
ENVIRONMENT=development

# ─── Monitoring (optional) ───
PROMETHEUS_PORT=9090
