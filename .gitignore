*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# ─── .NET (Core Backend) ───
**/bin/
**/obj/
**/out/
**/.vs/
*.user
*.suo
*.csproj.user
TestResults/
*.DotSettings

# ─── Node.js ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Docker ───
*.tar.gz

# ─── Kubernetes Secrets (asla commit etmeyin!) ───
# k8s/base/secrets.yaml  # Sadece template olarak commit edilebilir

# ─── OS ───
.DS_Store
Thumbs.db

# ─── Logs ───
*.log
logs/

# ─── Build outputs ───
frontend/dist/
frontend/build/
frontend/.next/
