{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=nl2sql;Username=nl2sql_user;Password=CHANGE_ME",
    "Redis": "redis:6379,password=CHANGE_ME,abortConnect=false,connectTimeout=5000"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "https://nl2sql.nurolteknoloji.com"]
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_jwt_secret_min_32_chars_long",
    "Issuer": "nl2sql-core-backend",
    "Audience": "nl2sql-frontend",
    "ExpireMinutes": 60
  },
  "AIBackend": {
    "BaseUrl": "http://ai-backend:8000"
  },
  "AllowedHosts": "*"
}
